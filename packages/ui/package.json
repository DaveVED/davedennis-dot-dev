{
  "name": "@repo/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./brandmark": "./src/brandmark.tsx",
    "./simple-background": "./src/simple-background.tsx",
    "./animated-title-with-lines": "./src/animated-title-with-lines.tsx",
    "./styles.css": "./dist/index.css",
    "./loading": "./src/loading.tsx",
    "./post-layout": "./src/post/layout.tsx",
    "./mdx-wrapper": "./src/post/mdx-wrapper.tsx",
    "./utili": "./src/util.ts"
  },
  "scripts": {
    "build": "tailwindcss -i ./src/styles.css -o ./dist/index.css",
    "dev": "tailwindcss -i ./src/styles.css -o ./dist/index.css --watch",
    "lint": "eslint . --max-warnings 0",
    "generate:component": "turbo gen react-component"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@turbo/gen": "^1.12.4",
    "@types/eslint": "^8.56.5",
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.3.3",
    "next-mdx-remote": "^5.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "react": "^18.2.0",
    "@tailwindcss/typography": "^0.5.13"
  }
}