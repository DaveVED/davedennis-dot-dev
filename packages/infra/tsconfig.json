{
  "extends": "@tsconfig/node20/tsconfig.json",
  "compilerOptions": {
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["esnext"],
    "module": "nodenext",
    "moduleDetection": "force",
    "moduleResolution": "nodenext",
    "skipLibCheck": true,
    "strict": true,
    "target": "esnext",
    "types": ["bun-types", "node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "exclude": ["**/test", "cdk.out", "node_modules"],
  "include": ["bun/stacks"]
}